ACIS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092   # Comma-separated Kafka broker addresses
ACIS_KAFKA_BACKEND=kafka-python               # kafka-python or confluent
ACIS_LOG_LEVEL=INFO                           # DEBUG, INFO, WARNING, ERROR
ACIS_OFFSET_RESET=latest                      # latest (normal) or earliest (replay mode — requires idempotent DBAgent)
ACIS_REGISTRY_PORT=5000                       # Port for the registry HTTP API
INDIAN_KANOON_API_KEY=                        # Required for litigation risk lookups. Get from indiankanoon.org
GROQ_API_KEY=                                 # Required for LLM risk extraction (ExternalScrapingAgent)
